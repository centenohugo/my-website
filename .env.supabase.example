# Copy to .env.supabase (gitignored) and fill in.
# This file is ONLY read by `npm run db:migrate:prod`. Never used by the app.
#
# Get the string from Supabase Dashboard -> Connect.
# Use the "Session pooler" string (IPv4-friendly, port 5432) for migrations:
#   postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
POSTGRES_URL=postgres://postgres.kcvalceicflauhmkcetj:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
